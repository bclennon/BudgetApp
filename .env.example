# Firebase configuration — required for Google Sign-In and cloud storage.
# Copy this file to .env.local and fill in your values for local development.
# For GitHub Pages deployment, add each variable as a repository secret.
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id_here
VITE_FIREBASE_APP_ID=your_firebase_app_id_here

# Plaid credentials — used by Firebase Cloud Functions only (never exposed to the browser).
# Set these via the Firebase CLI before deploying functions:
#   firebase functions:secrets:set PLAID_CLIENT_ID
#   firebase functions:secrets:set PLAID_SECRET
# For local emulator development, create functions/.env with:
#   PLAID_CLIENT_ID=your_plaid_client_id
#   PLAID_SECRET=your_plaid_secret
#   PLAID_ENV=sandbox
