# Google OAuth Client ID — required for Google SSO sign-in.
# Create a project at https://console.cloud.google.com, enable the
# "Google Identity Services" API, and create an OAuth 2.0 Web Client ID.
# Add your app's origin (e.g. http://localhost:5173) to the list of
# "Authorised JavaScript origins".
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
