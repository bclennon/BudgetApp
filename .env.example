# Firebase configuration — required for Google Sign-In.
# Copy this file to .env.local and fill in your values for local development.
# For GitHub Pages deployment, add each variable as a repository secret.
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id_here
VITE_FIREBASE_APP_ID=your_firebase_app_id_here

# Note: Firestore is no longer used. App data is stored directly in Google Sheets
# (one spreadsheet per user), using the Google Sheets API with the user's OAuth token
# obtained during Google Sign-In. No cloud functions or Firestore rules are required.
