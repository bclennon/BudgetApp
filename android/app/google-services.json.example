{
  "_comment": "This is an EXAMPLE template. Replace with your real google-services.json from the Firebase Console.",
  "project_info": {
    "project_number": "YOUR_PROJECT_NUMBER",
    "project_id": "YOUR_PROJECT_ID",
    "storage_bucket": "YOUR_PROJECT_ID.appspot.com"
  },
  "client": [
    {
      "client_info": {
        "mobilesdk_app_id": "1:YOUR_PROJECT_NUMBER:android:YOUR_APP_HASH",
        "android_client_info": {
          "package_name": "com.example.budgetapp"
        }
      },
      "oauth_client": [
        {
          "_comment": "This is the Android OAuth client (client_type: 1)",
          "client_id": "YOUR_PROJECT_NUMBER-ANDROID_HASH.apps.googleusercontent.com",
          "client_type": 1,
          "android_info": {
            "package_name": "com.example.budgetapp",
            "certificate_hash": "YOUR_SHA1_CERTIFICATE_HASH"
          }
        },
        {
          "_comment": "This is the web OAuth client (client_type: 3) — used as webClientId in AuthManager",
          "client_id": "YOUR_PROJECT_NUMBER-WEB_HASH.apps.googleusercontent.com",
          "client_type": 3
        }
      ],
      "api_key": [
        {
          "current_key": "YOUR_FIREBASE_API_KEY"
        }
      ],
      "services": {
        "appinvite_service": {
          "other_platform_oauth_client": [
            {
              "client_id": "YOUR_PROJECT_NUMBER-WEB_HASH.apps.googleusercontent.com",
              "client_type": 3
            }
          ]
        }
      }
    }
  ],
  "configuration_version": "1"
}
